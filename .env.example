# Frontend
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_WS_ENDPOINT=http://localhost:8080/api/v1/ws/board
VITE_REQUEST_TIMEOUT_MS=30000
VITE_LLM_REQUEST_TIMEOUT_MS=90000

# Runtime Profile
SPRING_PROFILES_ACTIVE=dev

# Backend Database
DB_URL=jdbc:postgresql://localhost:5432/flowboard
DB_USERNAME=flowboard
DB_PASSWORD=change-me
DB_MAX_POOL_SIZE=10
DB_MIN_IDLE=3
DB_CONNECTION_TIMEOUT_MS=30000

# Backend Security
JWT_SECRET=replace-with-a-random-secret-at-least-32-bytes
CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*
APP_LOG_LEVEL=INFO
SECURITY_LOG_LEVEL=WARN

# AI Provider
BEDROCK_REGION=us-east-2
BEDROCK_MODEL_ID=amazon.nova-micro-v1:0
BEDROCK_TIMEOUT_SECONDS=30
BEDROCK_MAX_TOKENS=2048
